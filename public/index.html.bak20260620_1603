<script>
// ═══════════════════════════════
// 🔔 NOTIFICACIONES PUSH
// ═══════════════════════════════
async function iniciarNotificacionesPush() {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) return;
  try {
    const reg = await navigator.serviceWorker.register('/sw.js');
    const permiso = await Notification.requestPermission();
    if (permiso !== 'granted') return;
    const vapidResp = await fetch('/api/push/vapidkey');
    const { publicKey } = await vapidResp.json();
    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: publicKey
    });
    const sesion = JSON.parse(localStorage.getItem('dt_sesion') || '{}');
    const userId = sesion.id || null;
    if (userId) {
      await fetch('/api/push/suscribir', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId, suscripcion: sub })
      });
      console.log('✅ Notificaciones push activadas');
    }
  } catch(e) {
    console.log('Push error:', e);
  }
}

window.addEventListener('load', () => {
  function intentarPush(intentos) {
    const sesion = JSON.parse(localStorage.getItem('dt_sesion') || '{}');
    if (sesion.id) {
      iniciarNotificacionesPush();
    } else if (intentos > 0) {
      setTimeout(() => intentarPush(intentos - 1), 5000);
    }
  }
  setTimeout(() => intentarPush(6), 3000);
});

// También llamar después del login
window.activarPushTrasLogin = iniciarNotificacionesPush;

// Detectar acción desde notificación push
(function() {
  const params = new URLSearchParams(window.location.search);
  const accion = params.get('accion');
  const clienteId = params.get('clienteId');
  if (!accion) return;

  let intentos = 0;
  const intervalo = setInterval(() => {
    intentos++;
    if (intentos > 30) { clearInterval(intervalo); return; }

    // Caso 1: entrenador quiere ver modal de cobro de un cliente
    if (accion === 'cobro' && clienteId) {
      const appEnt = document.getElementById('app-entrenador');
      if (appEnt && appEnt.style.display === 'block' && typeof abrirAdminCliente === 'function') {
        clearInterval(intervalo);
        setTimeout(() => abrirAdminCliente(clienteId), 300);
        return;
      }
    }

    // Caso 2: cliente ve su propio plan
    if (accion === 'mi-plan') {
      const appCli = document.getElementById('terminal-cliente-app');
      if (appCli && appCli.style.display !== 'none' && typeof tcTab === 'function') {
        clearInterval(intervalo);
        setTimeout(() => tcTab('rutina'), 300);
        return;
      }
    }
  }, 500);
})();

function actualizarEstadoPushUI() {
  const card = document.getElementById('push-estado-card');
  const txt = document.getElementById('push-estado-txt');
  const sub = document.getElementById('push-estado-sub');
  const btn = document.getElementById('push-estado-btn');
  if (!card || !txt) return;
  const perm = typeof Notification !== 'undefined' ? Notification.permission : 'denied';
  if (perm === 'granted') {
    card.style.background = '#1a3a1a';
    card.style.border = '1px solid #4caf50';
    txt.textContent = '🔔 Notificaciones activadas';
    sub.textContent = 'Toca para desactivar';
    btn.style.display = 'block';
    btn.style.background = '#4caf50';
    btn.textContent = 'Desactivar';
  } else if (perm === 'denied') {
    card.style.background = '#1a1a1a';
    card.style.border = '1px solid #e31e24';
    txt.textContent = '🔕 Notificaciones bloqueadas';
    sub.textContent = 'Ve a Configuración del navegador → Notificaciones → Permitir dt-app.net';
    btn.style.display = 'none';
  } else {
    card.style.background = '#1a1a1a';
    card.style.border = '1px solid #333';
    txt.textContent = '🔕 Notificaciones desactivadas';
    sub.textContent = 'Toca para recibir alertas de cobros y clientes';
    btn.style.display = 'block';
    btn.style.background = '#e31e24';
    btn.textContent = 'Activar';
  }
}

async function gestionarPushAdmin() {
  const permiso = Notification.permission;
  if (permiso === 'granted') {
    // Desactivar
    try {
      const reg = await navigator.serviceWorker.ready;
      const sub = await reg.pushManager.getSubscription();
      if (sub) {
        await sub.unsubscribe();
        const sesion = JSON.parse(localStorage.getItem('dt_sesion') || '{}');
        await fetch('/api/push/suscribir', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId: sesion.id, suscripcion: null })
        });
      }
      toast('🔕 Notificaciones desactivadas');
    } catch(e) { toast('Error al desactivar'); }
  } else {
    // Activar
    await iniciarNotificacionesPush();
    toast('🔔 Notificaciones activadas');
  }
  // Refrescar la vista
  if(window._adminData) {
    document.getElementById('admin-tab-content').innerHTML = renderAdminConfig();
  }
}
</script>
