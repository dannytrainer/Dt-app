  } else {
    contenedor.style.filter = '';
    contenedor.style.pointerEvents = '';
  }
}

function generarPlanAlimentario() {
  var id = window.clienteMedidasId || document.getElementById('rutina-cliente-id').value;
  if (!id) { toast('⚠️ Abre un cliente primero',false); return; }
  var btn = document.querySelector('[onclick="generarPlanAlimentario()"]');
  if (btn) btn.textContent = '⏳ Generando...';
  window._diaActual = 0;
  Promise.all([
    fetch('/api/alimentacion/'+id+'/plan',{method:'POST'}).then(function(r){return r.json();}),
    fetch('/api/alimentacion/'+id+'/semana').then(function(r){return r.json();})
  ]).then(function(results) {
    window._planActual = results[0];
    window._planSemana = results[1];
    var fecha = new Date(results[0].generado);
    document.getElementById('ali-plan-fecha').textContent = fecha.toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'});
    renderDiaPlan(results[1], 0);
    document.getElementById('modal-plan-ali').style.display = 'block';
    if (btn) btn.textContent = '⚡ Generar plan automático';
  }).catch(function(e) {
    alert('Error: '+e.message);
    if (btn) btn.textContent = '⚡ Generar plan automático';
  });
}

function compartirPlanWA() {
  var diaIdx = window._diaActual || 0;
  var plan = (window._planSemana && window._planSemana[diaIdx]) ? window._planSemana[diaIdx] : window._planActual;
  if (!plan) { toast('⚠️ Genera el plan primero',false); return; }
  var letras = ['A','B','C','D','E','F','G'];
  var letra = letras[diaIdx] || '';
  var id = window.clienteMedidasId;
  fetch('/api/usuarios/' + id)
    .then(function(r) { return r.json(); })
    .then(function(u) {
      var tel = (u.telefono || '').replace(/[^0-9]/g, '');
      var txt = '🍽️ *Plan alimentario — '+plan.nombre+'*\n';
      txt += '📅 '+new Date(plan.generado).toLocaleDateString('es-CO')+'\n';
      txt += '⚖️ Peso objetivo: '+plan.peso_objetivo+'kg\n\n';
      txt += '📊 *Totales del día:*\n';
      txt += '• Proteína: '+plan.totales.proteina+'g\n';
      txt += '• Carbos: '+plan.totales.carbohidratos+'g\n';
      txt += '• Grasas: '+plan.totales.grasas+'g\n';
      txt += '• Calorías: '+plan.totales.calorias+' kcal\n\n';
      plan.comidas.forEach(function(c) {
        var ico = c.nombre.indexOf('Desayuno')>=0?'🌅':c.nombre.indexOf('Snack')>=0?'🍎':c.nombre.indexOf('Almuerzo')>=0?'🍱':c.nombre.indexOf('Cena')>=0?'🌙':'⚡';
        txt += ico+' *'+c.nombre+'* ('+c.macros_reales.kcal+' kcal)\n';
        c.alimentos.forEach(function(al) { txt += '  • '+al.nombre+' ('+al.preparacion+'): *'+(al.unidad ? al.unidad.texto : al.porcion_g+'g')+'*\n'; });
        txt += '\n';
      });
      txt += '💪 _' + (JSON.parse(localStorage.getItem('dt_sesion')||'{}').nombre||'Entrenador') + ' — DT App_';
      var url = tel ? 'https://wa.me/'+tel+'?text='+encodeURIComponent(txt)
                    : 'https://wa.me/?text='+encodeURIComponent(txt);
      window.open(url, '_blank');
    })
    .catch(function() {
      toast('❌ No se pudo obtener el teléfono del cliente',false);
    });
}
</script>

