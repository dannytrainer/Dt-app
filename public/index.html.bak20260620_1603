async function cargarInicio(){
  try{
    const usuarios=await fetch('/api/usuarios?entrenador_id=' + (JSON.parse(localStorage.getItem('dt_sesion')||'{}').id||'ent_001')).then(r=>r.json());
    const activos=usuarios.filter(u=>u.activo);
