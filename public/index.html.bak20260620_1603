async function cargarMensajesEntrenador() {
  if (!_chatEntClienteId) return;
  const msgs = await fetch('/api/chat/' + _chatEntClienteId).then(r=>r.json()).catch(()=>[]);
  const cont = document.getElementById('chat-ent-mensajes');
