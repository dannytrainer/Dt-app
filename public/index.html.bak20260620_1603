/* ============================================
   GLASSMORPHISM — DT-APP
   ============================================ */

/* Variables adicionales glass */
:root {
  --glass-bg: rgba(255,255,255,0.05);
  --glass-bg-hover: rgba(255,255,255,0.08);
  --glass-border: rgba(255,255,255,0.10);
  --glass-border-rojo: rgba(227,30,36,0.25);
  --glass-header: rgba(8,8,8,0.80);
  --glass-modal: rgba(12,12,12,0.90);
  --rojo-glow: rgba(227,30,36,0.30);
  --shadow-card: 0 4px 24px rgba(0,0,0,0.4);
}

/* Fondo atmosférico */
body::before {
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse 60% 35% at 15% 0%, rgba(227,30,36,0.10) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 85% 90%, rgba(74,158,255,0.05) 0%, transparent 60%);
  pointer-events:none;
  z-index:0;
}

/* CARD glass */
.card {
  background: var(--glass-bg) !important;
  backdrop-filter: blur(12px) saturate(160%) !important;
  -webkit-backdrop-filter: blur(12px) saturate(160%) !important;
  border: 1px solid var(--glass-border) !important;
  border-radius: 14px !important;
  box-shadow: var(--shadow-card) !important;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.card::before {
  content:'';
  position:absolute;
  top:0; left:0; right:0;
  height:1px;
  background:linear-gradient(90deg, transparent, rgba(255,255,255,0.10), transparent);
  pointer-events:none;
}

.card:active {
  transform: scale(0.98);
}

.card.vencido {
  border-color: rgba(227,30,36,0.40) !important;
  box-shadow: 0 0 20px rgba(227,30,36,0.10), var(--shadow-card) !important;
}

.card.proximo {
  border-color: rgba(255,152,0,0.35) !important;
  box-shadow: 0 0 20px rgba(255,152,0,0.08), var(--shadow-card) !important;
}

/* HEADER glass */
.header {
  background: var(--glass-header) !important;
  backdrop-filter: blur(20px) saturate(180%) !important;
  -webkit-backdrop-filter: blur(20px) saturate(180%) !important;
  border-bottom: 1px solid var(--glass-border) !important;
  box-shadow: 0 2px 20px rgba(0,0,0,0.4) !important;
  position: relative;
}

.header::after {
  content:'';
  position:absolute;
  bottom:0; left:0; right:0;
  height:1px;
  background:linear-gradient(90deg, transparent, rgba(227,30,36,0.4), transparent);
  pointer-events:none;
}

/* NAV glass */
.nav {
  background: rgba(8,8,8,0.75) !important;
  backdrop-filter: blur(16px) !important;
  -webkit-backdrop-filter: blur(16px) !important;
  border-bottom: 1px solid var(--glass-border) !important;
}

.nav button {
  transition: color 0.2s ease, border-color 0.2s ease;
}

.nav button.active {
  text-shadow: 0 0 12px var(--rojo-glow);
}

/* MODAL glass */
.mc {
  background: var(--glass-modal) !important;
  backdrop-filter: blur(28px) saturate(180%) !important;
  -webkit-backdrop-filter: blur(28px) saturate(180%) !important;
  border-top: 1px solid var(--glass-border) !important;
  box-shadow: 0 -20px 60px rgba(0,0,0,0.6) !important;
  position: relative;
}

.mc::before {
  content:'';
  position:absolute;
  top:0; left:20%; right:20%;
  height:2px;
  background:linear-gradient(90deg, transparent, rgba(227,30,36,0.6), transparent);
  border-radius:2px;
  pointer-events:none;
}

.modal {
  backdrop-filter: blur(6px) !important;
  -webkit-backdrop-filter: blur(6px) !important;
}

/* BOTONES */
.btn {
  transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.15s ease !important;
}

.btn:active {
  transform: scale(0.97) !important;
}

.br {
  box-shadow: 0 4px 16px rgba(227,30,36,0.35) !important;
}

.br:hover {
  box-shadow: 0 6px 24px rgba(227,30,36,0.50) !important;
  opacity: 0.92;
}

/* FAB */
.fab {
  box-shadow: 0 6px 28px rgba(227,30,36,0.50), 0 0 0 4px rgba(227,30,36,0.10) !important;
  transition: transform 0.2s ease, box-shadow 0.2s ease !important;
}

.fab:active {
  transform: scale(0.93) !important;
}

/* INPUTS glass */
.ig input, .ig select, .ig textarea {
  background: rgba(255,255,255,0.04) !important;
  border: 1px solid var(--glass-border) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
  transition: border-color 0.2s ease, box-shadow 0.2s ease !important;
}

.ig input:focus, .ig select:focus, .ig textarea:focus {
  border-color: rgba(227,30,36,0.60) !important;
  box-shadow: 0 0 0 3px rgba(227,30,36,0.10) !important;
}

/* AVATAR glow */
.avatar {
  box-shadow: 0 4px 12px rgba(227,30,36,0.30) !important;
}

/* TOAST glass */
.toast {
  background: var(--card) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  box-shadow: 0 4px 20px rgba(0,0,0,0.15) !important;
}

/* TABS glass */
.dtab button {
  background: rgba(255,255,255,0.04) !important;
  border-color: var(--glass-border) !important;
  transition: all 0.2s ease !important;
}

.dtab button.active {
  background: var(--rojo) !important;
  box-shadow: 0 4px 14px rgba(227,30,36,0.35) !important;
}

/* Fade-in páginas */
.page.active {
  animation: fadeInPage 0.25s ease forwards;
}

@keyframes fadeInPage {
  from { opacity:0; transform:translateY(6px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ---- MODO CLARO glass ---- */
body.modo-claro {
  --glass-bg: rgba(255,255,255,0.65) !important;
  --glass-bg-hover: rgba(255,255,255,0.80) !important;
  --glass-border: rgba(0,0,0,0.07) !important;
  --glass-border-rojo: rgba(227,30,36,0.20) !important;
  --glass-header: rgba(255,255,255,0.82) !important;
  --glass-modal: rgba(252,252,254,0.93) !important;
  --shadow-card: 0 4px 20px rgba(0,0,0,0.08) !important;
}

body.modo-claro::before {
  background:
    radial-gradient(ellipse 60% 35% at 15% 0%, rgba(227,30,36,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 85% 90%, rgba(74,158,255,0.04) 0%, transparent 60%);
}

body.modo-claro .nav {
  background: rgba(255,255,255,0.80) !important;
}

body.modo-claro .header::after {
  background: linear-gradient(90deg, transparent, rgba(227,30,36,0.25), transparent);
}

body.modo-claro .ig input,
body.modo-claro .ig select,
body.modo-claro .ig textarea {
  background: rgba(0,0,0,0.03) !important;
  border-color: rgba(0,0,0,0.09) !important;
}


