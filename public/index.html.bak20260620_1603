  totales += '<div style="background:var(--gris);border-radius:8px;padding:8px;text-align:center"><div style="font-size:15px;font-weight:800;color:#f0a500">'+t.carbohidratos+'g</div><div style="font-size:9px;color:var(--texto-secundario)">Carbos</div></div>';
  totales += '<div style="background:var(--gris);border-radius:8px;padding:8px;text-align:center"><div style="font-size:15px;font-weight:800;color:#4caf50">'+t.grasas+'g</div><div style="font-size:9px;color:var(--texto-secundario)">Grasas</div></div>';
  totales += '<div style="background:var(--gris);border-radius:8px;padding:8px;text-align:center"><div style="font-size:15px;font-weight:800;color:var(--texto)">'+t.calorias+'</div><div style="font-size:9px;color:var(--texto-secundario)">kcal</div></div>';
  totales += '</div>';
  var letEl = document.getElementById('ali-plan-letra');
  if(letEl) letEl.textContent = 'Plan '+(letrasPlanes[diaIdx]||diaIdx+1);
  var comidas = '';
  dia.comidas.forEach(function(comida) {
    var mr = comida.macros_reales;
    var ico = comida.nombre.indexOf('Desayuno')>=0?'🌅':comida.nombre.indexOf('Snack')>=0?'🍎':comida.nombre.indexOf('Almuerzo')>=0?'🍱':comida.nombre.indexOf('Cena')>=0?'🌙':comida.nombre.indexOf('Pre')>=0?'⚡':'🍽️';
    var h = '<div style="background:var(--card);border:1px solid var(--borde);border-radius:12px;padding:12px;margin-bottom:10px">';
    h += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px"><div style="font-size:14px;font-weight:800;color:var(--texto)">'+ico+' '+comida.nombre+'</div><div style="font-size:12px;color:var(--texto-medio);font-weight:600">'+mr.kcal+' kcal</div></div>';
    var p1=Math.round(mr.proteina*10)/10, c1=Math.round(mr.carbos*10)/10, g1=Math.round(mr.grasas*10)/10;
    h += '<div style="display:flex;gap:6px;margin-bottom:10px"><span style="font-size:10px;background:#1a0a0a;color:#e31e24;border-radius:6px;padding:3px 8px">P: '+p1+'g</span><span style="font-size:10px;background:#1a120a;color:#f0a500;border-radius:6px;padding:3px 8px">C: '+c1+'g</span><span style="font-size:10px;background:#0a1a0a;color:#4caf50;border-radius:6px;padding:3px 8px">G: '+g1+'g</span></div>';
    comida.alimentos.forEach(function(al) {
      h += '<div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-top:1px solid var(--borde)">';
      var cAlim=document.body.classList.contains('modo-claro')?'#111':'#ddd';var cDet=document.body.classList.contains('modo-claro')?'#555':'#666';h += '<div style="flex:1"><div style="font-size:13px;color:'+cAlim+';font-weight:600">'+al.nombre+(al.detalle?' <span style="color:'+cDet+';font-size:10px">('+al.detalle+')</span>':'')+'</div>';
      h += '<div style="font-size:10px;color:var(--texto-tenue);margin-top:2px">'+al.macros.proteina+'g P · '+al.macros.carbohidratos+'g C · '+al.macros.grasas+'g G</div></div>';
